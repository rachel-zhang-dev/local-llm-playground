# Copy to .env and fill in what you have.
# Anything left blank just disables the matching provider; local Ollama works
# without setting anything.

# Local Ollama host (default works if you started `ollama serve` on this Mac)
OLLAMA_HOST=http://localhost:11434

# Default model used by llm-chat / examples when --model is not passed.
DEFAULT_MODEL=deepseek-r1:14b

# Optional: OpenAI API key (lets you point at openai/gpt-5.5)
# OPENAI_API_KEY=sk-...

# Optional: Xiaomi MiMo UltraSpeed API key (after the trial approval email)
# MIMO_API_KEY=...
# MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# Optional: WeChat 公众号 sandbox (only needed for `llm-wechat`)
# Get appID + appsecret from https://mp.weixin.qq.com/debug/cgi-bin/sandbox?t=sandbox/login
# Token is anything you pick (>= 3 chars); paste the same value into the sandbox URL form.
# WECHAT_TOKEN=
# WECHAT_APPID=
# WECHAT_APPSECRET=
